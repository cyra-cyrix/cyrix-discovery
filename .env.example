# Copy to .env for local `netlify dev`. In production these are set in the
# Netlify UI under Site configuration → Environment variables.

# The Innovation Team's access token. Verified server-side; never in the bundle.
# Generate one: openssl rand -hex 24
ADMIN_TOKEN=

# The Anthropic key. Server-side only — a VITE_* variable would be public.
ANTHROPIC_API_KEY=
